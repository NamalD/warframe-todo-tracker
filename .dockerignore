# ============================================================
# Dependencies — NEVER include these in Docker build context
# ============================================================
node_modules/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz

# ============================================================
# Next.js build output (the Dockerfile builds its own)
# ============================================================
.next/
out/

# ============================================================
# Testing
# ============================================================
coverage/
.nyc_output/
playwright-report/
test-results/

# ============================================================
# Environment files (security — never leak secrets to image)
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Project-specific: development-only artifacts
# ============================================================
docs/
.hermes/
data/

# ============================================================
# Git
# ============================================================
.git/
.gitattributes
.gitignore

# ============================================================
# CI / GitHub
# ============================================================
.github/

# ============================================================
# OS / editor artifacts
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Misc
# ============================================================
README.md
LICENSE
