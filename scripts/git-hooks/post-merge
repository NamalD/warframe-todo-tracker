#!/bin/bash
# post-merge — see docker-redeploy.sh
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

CURRENT=$(git rev-parse HEAD)
PREVIOUS=$(git rev-parse HEAD@{1} 2>/dev/null || echo "")
if [ "$CURRENT" = "$PREVIOUS" ] || [ -z "$PREVIOUS" ]; then
    exit 0
fi

exec "$DIR/docker-redeploy.sh" "HEAD@{1}..HEAD"
